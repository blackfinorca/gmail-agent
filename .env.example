# Gmail OAuth — generate via Google Cloud Console
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# OpenAI — separate keys per pipeline (can be the same key if you prefer)
OPENAI_API_KEY_EMAILS=your_key_here
OPENAI_API_KEY_PDF=your_key_here
# Models: emails = text summaries, pdf = multimodal invoice extraction
OPENAI_MODEL=gpt-4o-mini
OPENAI_PDF_MODEL=gpt-4o-mini

# Agent config
POLL_INTERVAL_SECONDS=300
MAX_SUMMARY_TOKENS=400
DB_PATH=./agent.db
CREDENTIALS_DIR=./credentials
LOG_FILE=./agent.log
